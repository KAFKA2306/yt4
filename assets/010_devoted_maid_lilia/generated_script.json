[
  { "text": "（激しい雨が窓を叩く音。遠くで雷鳴が微かに響く）", "pause": 5.0, "emotion": { "valence": 0.4, "arousal": 0.2, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（扉が静かに開閉される音。重厚な鍵を二重にかける音）", "pause": 6.0, "emotion": { "valence": 0.4, "arousal": 0.2, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……ふふ。まだ起きていらしたのですね、私のご主人様。", "pause": 4.0, "emotion": { "valence": 0.45, "arousal": 0.18, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "深夜の2時をとうに過ぎています。こんな時間まで、お一人で何をされていたのですか？", "pause": 5.0, "emotion": { "valence": 0.45, "arousal": 0.18, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（ゆっくりとした足音が近づく。床がわずかに軋む音）", "pause": 5.0, "emotion": { "valence": 0.5, "arousal": 0.15, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "お顔色が優れませんね。……あぁ、また無理をなさって。私の言いつけ、忘れてしまったのですか？", "pause": 5.5, "emotion": { "valence": 0.5, "arousal": 0.15, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "「夜更かしは禁止です」と、あれほど約束したはずなのに。……ふふ、悪い子ですね。", "pause": 6.0, "emotion": { "valence": 0.5, "arousal": 0.15, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（衣擦れの音。背後に回り込む気配）", "pause": 4.0, "emotion": { "valence": 0.5, "arousal": 0.15, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ほら、肩に力が入っていますよ。私がほぐしてあげますから、リラックスしてくださいね。", "pause": 5.0, "emotion": { "valence": 0.5, "arousal": 0.15, "softness": 0.85, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（ジャケットのボタンを外す音）", "pause": 6.0, "emotion": { "valence": 0.52, "arousal": 0.14, "softness": 0.86, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "失礼いたします。まずはこの重苦しいジャケットを脱ぎましょうか。一つ、二つ……。", "pause": 5.0, "emotion": { "valence": 0.52, "arousal": 0.14, "softness": 0.86, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（布が滑り落ちる音）", "pause": 4.0, "emotion": { "valence": 0.52, "arousal": 0.14, "softness": 0.86, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "はい、脱げました。次は……あぁ、シャツの襟元も少し緩めさせていただきますね。", "pause": 5.0, "emotion": { "valence": 0.52, "arousal": 0.14, "softness": 0.86, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（肌に触れる指の感触。吐息）", "pause": 4.0, "emotion": { "valence": 0.55, "arousal": 0.13, "softness": 0.87, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……。ご主人様の体、少し冷えています。雨のせいでしょうか、それとも……私がいなくて寂しかったから？", "pause": 6.0, "emotion": { "valence": 0.55, "arousal": 0.13, "softness": 0.87, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（本格的に肩を揉み始める音。グッグッという規則的な音）", "pause": 7.0, "emotion": { "valence": 0.55, "arousal": 0.13, "softness": 0.87, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "これくらいの強さで大丈夫ですか？　……あぁ、本当にカチカチです。", "pause": 5.5, "emotion": { "valence": 0.55, "arousal": 0.13, "softness": 0.87, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "毎日毎日、お仕事ばかり。ご主人様は、私がいないとすぐに自分を壊してしまいますね。", "pause": 6.0, "emotion": { "valence": 0.58, "arousal": 0.12, "softness": 0.88, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（親指で首筋を圧迫する音）", "pause": 5.0, "emotion": { "valence": 0.58, "arousal": 0.12, "softness": 0.88, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ここは痛いですか？　……ふふ。声を我慢しなくていいんですよ。この部屋には私しかいないのですから。", "pause": 6.0, "emotion": { "valence": 0.58, "arousal": 0.12, "softness": 0.88, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（首から背中にかけてさすり下ろす音）", "pause": 6.0, "emotion": { "valence": 0.6, "arousal": 0.11, "softness": 0.89, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ご主人様の全てを癒せるのは、私だけ。他の誰にも、この特権は譲りません……。", "pause": 6.5, "emotion": { "valence": 0.6, "arousal": 0.11, "softness": 0.89, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（一旦離れて、カップを用意する音）", "pause": 5.0, "emotion": { "valence": 0.6, "arousal": 0.1, "softness": 0.9, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "少し喉を潤しましょう。特別にブレンドした、眠りを誘うハーブティーです。", "pause": 5.0, "emotion": { "valence": 0.6, "arousal": 0.1, "softness": 0.9, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（お湯を注ぐ音。立ち上る湯気の気配）", "pause": 7.0, "emotion": { "valence": 0.62, "arousal": 0.09, "softness": 0.91, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "良い香りでしょう？　ラベンダーと、少しだけ秘密のスパイスを混ぜてあります。", "pause": 5.5, "emotion": { "valence": 0.62, "arousal": 0.09, "softness": 0.91, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（カップを差し出す音。スプーンが触れ合うチリンという音）", "pause": 6.0, "emotion": { "valence": 0.62, "arousal": 0.09, "softness": 0.91, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "はい、どうぞ。熱いですから、ゆっくり含んでくださいね。……ふー、ふー……。", "pause": 8.0, "emotion": { "valence": 0.65, "arousal": 0.08, "softness": 0.92, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……飲み終わりましたか？　偉いですね。これで心も体も、少しずつ私に溶けていきますよ。", "pause": 6.0, "emotion": { "valence": 0.65, "arousal": 0.08, "softness": 0.92, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（椅子を引き、座る音。ブラシを取り出す音）", "pause": 5.0, "emotion": { "valence": 0.7, "arousal": 0.07, "softness": 0.93, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "さて……。次は、乱れた髪を整えさせていただきましょうか。", "pause": 5.0, "emotion": { "valence": 0.7, "arousal": 0.07, "softness": 0.93, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（髪にブラシを通す規則的な音。サッ、サッ、という音）", "pause": 10.0, "emotion": { "valence": 0.7, "arousal": 0.07, "softness": 0.93, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……。綺麗な髪。指を通すたびに、ご主人様の香りがして……、胸が苦しくなります。", "pause": 6.5, "emotion": { "valence": 0.72, "arousal": 0.06, "softness": 0.94, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（さらに丁寧にブラッシングする音）", "pause": 12.0, "emotion": { "valence": 0.72, "arousal": 0.06, "softness": 0.94, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "あぁ……。抜け毛がありますね。これも、私が大切に保管しておきますね？", "pause": 6.0, "emotion": { "valence": 0.75, "arousal": 0.06, "softness": 0.95, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（ブラシを置き、手櫛で整える音）", "pause": 8.0, "emotion": { "valence": 0.75, "arousal": 0.06, "softness": 0.95, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ふふ、そんなに怯えないでください。メイドが主人の一部を大切にするのは、当然のことですから。", "pause": 6.5, "emotion": { "valence": 0.75, "arousal": 0.06, "softness": 0.95, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（頭を優しく撫でる音。髪を指に巻きつける音）", "pause": 7.0, "emotion": { "valence": 0.78, "arousal": 0.06, "softness": 0.96, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……愛おしい。本当に、心から。あなたが私の腕の中にいるだけで、世界は完結するのです。", "pause": 7.0, "emotion": { "valence": 0.78, "arousal": 0.06, "softness": 0.96, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（ベッドのシーツが擦れる音。横になるよう促す気配）", "pause": 5.0, "emotion": { "valence": 0.8, "arousal": 0.05, "softness": 0.97, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "さあ、そろそろ横になりましょうか。今日は特別に、私の膝で眠らせてあげます。", "pause": 6.0, "emotion": { "valence": 0.8, "arousal": 0.05, "softness": 0.97, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（膝枕をする音。衣擦れの柔らかな音）", "pause": 8.0, "emotion": { "valence": 0.82, "arousal": 0.05, "softness": 0.97, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ふふ……、あったかい。ご主人様の重みをこうして太ももに感じられる時間が、何よりの至福です。", "pause": 6.5, "emotion": { "valence": 0.82, "arousal": 0.05, "softness": 0.97, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（耳元での囁き。吐息）", "pause": 5.0, "emotion": { "valence": 0.85, "arousal": 0.05, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "お耳、掃除させていただきますね。リラックスして……、そのまま目を閉じていてください。", "pause": 6.0, "emotion": { "valence": 0.85, "arousal": 0.05, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（竹の耳かきを用意する音。カサカサというかすかな音）", "pause": 5.0, "emotion": { "valence": 0.85, "arousal": 0.05, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "まずは右のお耳から……。失礼いたしますね。", "pause": 4.0, "emotion": { "valence": 0.86, "arousal": 0.05, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（耳の外側、耳介をなぞる音。カサ……カサ……）", "pause": 8.0, "emotion": { "valence": 0.86, "arousal": 0.05, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "こそばゆいですか？　ふふ、耳の形をなぞるの、大好きなんです。まるで私の所有印を刻んでいるようで。", "pause": 7.0, "emotion": { "valence": 0.86, "arousal": 0.05, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（右耳の入り口付近をカリカリと掻く音）", "pause": 10.0, "emotion": { "valence": 0.87, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "かさ……こそ……。かさこそ……。力を抜いて。大丈夫、傷つけたりしませんよ。", "pause": 7.5, "emotion": { "valence": 0.87, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（少しずつ奥の方へ。カサカサという乾いた音）", "pause": 12.0, "emotion": { "valence": 0.88, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "こそこそ……。……あ、耳垢が見えます。かなり溜まっていますね。お仕事が忙しくて、余裕がなかったのでしょう？", "pause": 8.0, "emotion": { "valence": 0.88, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（大きな耳垢を剥がす音。ペリッという感覚のある音）", "pause": 6.0, "emotion": { "valence": 0.88, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "おぉ……、大きな塊。取れましたよ。見てください……ふふ。私の膝の上で、こんなに綺麗になっていく……。", "pause": 7.0, "emotion": { "valence": 0.89, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（さらに奥を丁寧に掃除する音。連続的な「カサカサ」音）", "pause": 15.0, "emotion": { "valence": 0.89, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "かさこそ……、かさこそ……。気持ちいいですか……？　脈拍が少し早くなっていますね。", "pause": 8.0, "emotion": { "valence": 0.89, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（右耳の壁面をぐるりと一周回す音）", "pause": 10.0, "emotion": { "valence": 0.9, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "こそ……、こそ……。……。本当に、ご主人様は無防備ですね。私がこうして耳かきをしている間、何があっても抵抗できない……。", "pause": 9.0, "emotion": { "valence": 0.9, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（耳かきの先端で優しく突く音。トントン、という音）", "pause": 8.0, "emotion": { "valence": 0.9, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "とん、とん、とん……。心地よいリズムでしょう？　そのまま、私の体温に溶けてしまえばいいんです。", "pause": 7.5, "emotion": { "valence": 0.9, "arousal": 0.04, "softness": 0.98, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（右耳の仕上げ。耳介の溝を掃除する音）", "pause": 12.0, "emotion": { "valence": 0.91, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "かさっ……こそ……。かさこそ……。……。はい、右耳はこれくらいにしましょうか。", "pause": 6.0, "emotion": { "valence": 0.91, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（耳に息を吹きかける「ふーっ」という長い音）", "pause": 8.0, "emotion": { "valence": 0.91, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "次は左のお耳ですね。ゆっくり、こちらに顔を向けてください。……あぁ、いい子ですね。", "pause": 7.0, "emotion": { "valence": 0.92, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（左耳の入り口をなぞる音。カサ……カサ……）", "pause": 9.0, "emotion": { "valence": 0.92, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "左のお耳も、同じように綺麗にしてあげますよ。……かさこそ……。", "pause": 8.0, "emotion": { "valence": 0.92, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（左耳の掃除。カリカリ、という乾いた音が続く）", "pause": 15.0, "emotion": { "valence": 0.93, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "かさっ……、かさこそ。……ふふ。少し身震いしましたね。敏感なところ、見つけちゃいました。", "pause": 8.0, "emotion": { "valence": 0.93, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（その場所を重点的に攻める音。細かく、速い「カサカサ」音）", "pause": 12.0, "emotion": { "valence": 0.93, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "かさかさかさ……。ここですか？　それともここ……？　……あぁ、そんな顔をされると、もっと意地悪したくなります。", "pause": 9.0, "emotion": { "valence": 0.94, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（再びゆっくりと。深い「カサ……」音）", "pause": 10.0, "emotion": { "valence": 0.94, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "かさ……こそ……。かさこそ。……。雨の音が、だんだん遠くなっていきますね。", "pause": 8.0, "emotion": { "valence": 0.94, "arousal": 0.03, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（左耳の奥を掃除する音。深い場所を掻く音）", "pause": 15.0, "emotion": { "valence": 0.95, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "こそこそ……。……よし、こちらも大きなのが取れました。これで、世界には私の声しか聞こえなくなりますね。", "pause": 9.0, "emotion": { "valence": 0.95, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（梵天（ふわふわ）を取り出す音。カサカサ、という柔らかな音）", "pause": 6.0, "emotion": { "valence": 0.95, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "仕上げに、このふわふわした梵天でお耳を撫でます。……ふふ、くすぐったいですよ？", "pause": 7.0, "emotion": { "valence": 0.95, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（右耳、左耳と交互に梵天で撫でる音。パサ、パサ、という音）", "pause": 15.0, "emotion": { "valence": 0.96, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ぱさ、ぱさ……。ぱさ……。……。ご主人様、もう夢の中でしょうか。", "pause": 8.0, "emotion": { "valence": 0.96, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（耳かき一式を片付ける音。さらに接近する気配）", "pause": 6.0, "emotion": { "valence": 0.96, "arousal": 0.02, "softness": 0.99, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……。寝顔、独り占めです。誰にも見せたくない。このまま、時間が止まってしまえばいいのに。", "pause": 10.0, "emotion": { "valence": 0.97, "arousal": 0.02, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（耳元での極めて低い囁き。リップ音）", "pause": 7.0, "emotion": { "valence": 0.97, "arousal": 0.02, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……。ねぇ、ご主人様。あなたはもう、私なしでは生きていけませんよね？", "pause": 8.0, "emotion": { "valence": 0.98, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（顔を近づける気配。衣擦れと体温が伝わる距離）", "pause": 10.0, "emotion": { "valence": 0.98, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "食事も、睡眠も、癒しも。全て私が管理してあげます。あなたはただ、私に甘えていればいいのです。", "pause": 9.0, "emotion": { "valence": 0.98, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（指で唇をなぞる音）", "pause": 8.0, "emotion": { "valence": 0.99, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "この唇から漏れる吐息も、私だけのもの。他の女……いえ、他の誰にも触れさせません。", "pause": 9.0, "emotion": { "valence": 0.99, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（強く抱きしめるような衣擦れの音）", "pause": 12.0, "emotion": { "valence": 0.99, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "ずっと、ずっと。この狭い部屋で、私だけを見ていてください。私だけを感じていてください。", "pause": 10.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（髪の毛を愛おしそうに何度も撫でる音）", "pause": 15.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "あぁ、幸せ……。こうしていると、あなたは私の胎内に戻ったかのように、安らかで……。", "pause": 9.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "眠りなさい。私の小さなご主人様。夢の中でも、私の愛に溺れてください。", "pause": 10.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（おでこにキスをする音。チュッ、という音）", "pause": 8.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "……。愛しています。永遠に、逃がしませんから。", "pause": 10.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（最後に優しく耳元で息を吹きかける音。吐息が長く続く）", "pause": 12.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } },
  { "text": "（雨音だけが静かに響き、フェードアウトしていく）", "pause": 15.0, "emotion": { "valence": 1.0, "arousal": 0.01, "softness": 1.0, "atmosphere": "late-night-obsessive-maid" } }
]
